# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=

# LM Studio local inference server (default port)
LM_STUDIO_URL=http://localhost:1234/v1

# Exact model name as shown in LM Studio (e.g. qwen3.5-9b or llama-3.2-3b-instruct)
MODEL_NAME=qwen3.5-9b-claude-4.6-opus-reasoning-distilled

# Your Telegram user ID (get it from @userinfobot)
ALLOWED_USER_ID=

# The directory copilot/gemini will run inside (auto-created at startup)
WORKSPACE_DIR=./workspace

# Seconds before a CLI subprocess is killed (default: 120)
CLI_TIMEOUT_SECS=120

# Model passed to the copilot CLI via --model (leave unset to use copilot's default)
# COPILOT_MODEL=gpt-4.1

# Cron expression for the proactive heartbeat (6-field Quartz, UTC).
# Default: every hour on the hour. Set to "* * * * * *" for testing (every second).
# HEARTBEAT_CRON="0 0 * * * *"

# Model for background tasks (heartbeat curiosity research, interest checks).
# Falls back to COPILOT_MODEL if unset. Use a cheaper model to reduce costs.
# BACKGROUND_COPILOT_MODEL=claude-haiku-4.5

# Model for background LM Studio tasks (memory eval, context compression).
# Falls back to MODEL_NAME if unset. Memory eval is now on-path (awaited), so
# setting this to a smaller/faster model reduces per-conversation latency.
# BACKGROUND_LM_MODEL=llama-3.2-3b-instruct

# Hours of silence before treating the next message as a resumed session.
# On the first turn of a resumed session, a summary of recent history is generated
# and injected so the bot can pick up naturally. Default: 2.
# SESSION_GAP_HOURS=2

# Minimum conversation messages in history required to generate a session summary.
# Prevents summaries on very short sessions. Default: 6 (>=3 turns).
# SESSION_SUMMARY_MIN_MESSAGES=6

# Maximum number of messages retained per conversation history file.
# Oldest messages are dropped first when the limit is exceeded. Default: 500.
# HISTORY_MAX_STORED=500

# Number of episodic entries since last consolidation before the consolidation
# pass fires. Default: 15. Lower to 3 for testing.
# CONSOLIDATION_THRESHOLD=15

# Max agentic loop iterations per execution context.
# Tune up for complex multi-step tasks; tune down to reduce LM cost.
# LOOP_ITERS_CONVERSATION=20
# LOOP_ITERS_HEARTBEAT=12
# LOOP_ITERS_CONSOLIDATION=10
# LOOP_ITERS_AGENDA=20
# LOOP_CONTEXT_THRESHOLD=30
